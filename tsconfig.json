{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@prisma/generated/*": [
        "./src/prisma/generated/*"
      ],
      "@tests/*": [
        "./tests/*"
      ]
    },
    "outDir": "./dist"
  },
  "include": [
    "src",
    "tests"
  ]
}