generator client {
  provider = "prisma-client"
  output   = "generated"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  phone       String
  city        String
  state       String
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  pets        Pet[]
}

model Pet {
  id             String       @id @default(uuid())
  name           String
  age            Int
  size           Size
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}
